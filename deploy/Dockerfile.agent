FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /grumble-agent ./cmd/agent

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /grumble-agent /usr/bin/grumble-agent
ENTRYPOINT ["/usr/bin/grumble-agent"]
