{
  "title": "Grumble — Image Catalog & Vulnerability Hotspots",
  "uid": "grumble-hotspots",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5m",
  "tags": ["security", "grumble", "grype"],
  "templating": {
    "list": [
      {
        "name": "image_filter",
        "label": "Image",
        "type": "textbox",
        "current": { "value": "" },
        "hide": 0,
        "options": [],
        "query": ""
      },
      {
        "name": "severity_filter",
        "label": "Severity",
        "type": "custom",
        "current": { "value": "", "text": "All" },
        "hide": 0,
        "options": [
          { "value": "",         "text": "All",     "selected": true },
          { "value": "Critical", "text": "Critical", "selected": false },
          { "value": "High",     "text": "High",     "selected": false },
          { "value": "Medium",   "text": "Medium",   "selected": false },
          { "value": "Low",      "text": "Low",      "selected": false }
        ],
        "query": "All,Critical,High,Medium,Low"
      },
      {
        "name": "package_search",
        "label": "Package Name",
        "type": "textbox",
        "current": { "value": "" },
        "hide": 0,
        "options": [],
        "query": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Critical CVEs",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/hotspots", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [{ "selector": "critical", "text": "critical", "type": "number" }]
      }]
    },
    {
      "id": 2,
      "title": "Total High CVEs",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["sum"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/hotspots", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [{ "selector": "high", "text": "high", "type": "number" }]
      }]
    },
    {
      "id": 3,
      "title": "Clusters Reporting",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["count"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/clusters", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [{ "selector": "cluster_id", "text": "cluster_id", "type": "string" }]
      }]
    },
    {
      "id": 11,
      "title": "Images Scanned",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["count"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/hotspots", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [{ "selector": "image", "text": "image", "type": "string" }]
      }]
    },
    {
      "id": 4,
      "title": "Top Vulnerability Hotspots",
      "description": "Images ranked by risk score = (critical×10 + high×3 + medium) × pod count",
      "type": "table",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "options": { "sortBy": [{ "displayName": "risk_score", "desc": true }] },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "risk_score" },
            "properties": [
              { "id": "custom.width", "value": 120 },
              { "id": "custom.displayMode", "value": "lcd-gauge" },
              { "id": "max", "value": 1000 }
            ]
          }
        ]
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/hotspots", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "image",      "text": "image",      "type": "string" },
          { "selector": "cluster_id", "text": "cluster_id", "type": "string" },
          { "selector": "critical",   "text": "critical",   "type": "number" },
          { "selector": "high",       "text": "high",       "type": "number" },
          { "selector": "medium",     "text": "medium",     "type": "number" },
          { "selector": "low",        "text": "low",        "type": "number" },
          { "selector": "pod_count",  "text": "pod_count",  "type": "number" },
          { "selector": "risk_score", "text": "risk_score", "type": "number" },
          { "selector": "scanned_at", "text": "scanned_at", "type": "string" }
        ]
      }]
    },
    {
      "id": 5,
      "title": "Critical CVEs per Cluster",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/clusters", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "cluster_id", "text": "cluster_id", "type": "string" },
          { "selector": "critical",   "text": "critical",   "type": "number" }
        ]
      }]
    },
    {
      "id": 6,
      "title": "Pod Inventory",
      "type": "table",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/inventory", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "cluster_id", "text": "cluster_id", "type": "string" },
          { "selector": "namespace",  "text": "namespace",  "type": "string" },
          { "selector": "pod_name",   "text": "pod_name",   "type": "string" },
          { "selector": "image",      "text": "image",      "type": "string" },
          { "selector": "phase",      "text": "phase",      "type": "string" }
        ]
      }]
    },
    {
      "id": 8,
      "title": "Image Catalog — All Running Images",
      "description": "Every unique image observed across all clusters with pod counts and vuln summary.",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 10 },
      "options": { "sortBy": [{ "displayName": "total_vulns", "desc": true }] },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "scan_status" },
            "properties": [
              { "id": "custom.width", "value": 110 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "scanned": { "color": "green", "text": "✓ scanned" } } },
                { "type": "value", "options": { "pending": { "color": "yellow", "text": "⏳ pending" } } }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "high" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }] } },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/images", "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "image",       "text": "image",       "type": "string" },
          { "selector": "cluster_id",  "text": "cluster_id",  "type": "string" },
          { "selector": "pod_count",   "text": "pod_count",   "type": "number" },
          { "selector": "namespaces",  "text": "namespaces",  "type": "string" },
          { "selector": "critical",    "text": "critical",    "type": "number" },
          { "selector": "high",        "text": "high",        "type": "number" },
          { "selector": "medium",      "text": "medium",      "type": "number" },
          { "selector": "total_vulns", "text": "total_vulns", "type": "number" },
          { "selector": "scan_status", "text": "scan_status", "type": "string" },
          { "selector": "last_seen",   "text": "last_seen",   "type": "string" }
        ]
      }]
    },
    {
      "id": 10,
      "title": "Vulnerability Detail — CVEs by Image",
      "description": "Use the Image filter at the top to drill into a specific image. Severity filter narrows by level.",
      "type": "table",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 12 },
      "options": { "sortBy": [{ "displayName": "severity", "desc": false }] },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "Critical": { "color": "red",    "text": "Critical" } } },
                { "type": "value", "options": { "High":     { "color": "orange", "text": "High"     } } },
                { "type": "value", "options": { "Medium":   { "color": "yellow", "text": "Medium"   } } },
                { "type": "value", "options": { "Low":      { "color": "blue",   "text": "Low"      } } }
              ]},
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "vuln_id" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          },
          {
            "matcher": { "id": "byName", "options": "description" },
            "properties": [{ "id": "custom.width", "value": 400 }]
          }
        ]
      },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/vulns?image=${image_filter}&severity=${severity_filter}",
        "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "vuln_id",      "text": "vuln_id",      "type": "string" },
          { "selector": "severity",     "text": "severity",     "type": "string" },
          { "selector": "package_name", "text": "package_name", "type": "string" },
          { "selector": "version",      "text": "version",      "type": "string" },
          { "selector": "fixed_in",     "text": "fixed_in",     "type": "string" },
          { "selector": "image",        "text": "image",        "type": "string" },
          { "selector": "description",  "text": "description",  "type": "string" }
        ]
      }]
    },
    {
      "id": 9,
      "title": "Package / Dependency Search",
      "description": "Search by package name (e.g. openssl, curl). Shows every image running that package.",
      "type": "table",
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 9 },
      "options": { "sortBy": [{ "displayName": "pod_count", "desc": true }] },
      "targets": [{
        "refId": "A",
        "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "grumble-api" },
        "type": "json", "parser": "backend", "source": "url", "format": "table",
        "url": "/packages?name=${package_search}",
        "url_options": { "method": "GET" }, "root_selector": "",
        "columns": [
          { "selector": "name",       "text": "name",       "type": "string" },
          { "selector": "version",    "text": "version",    "type": "string" },
          { "selector": "type",       "text": "type",       "type": "string" },
          { "selector": "image",      "text": "image",      "type": "string" },
          { "selector": "cluster_id", "text": "cluster_id", "type": "string" },
          { "selector": "pod_count",  "text": "pod_count",  "type": "number" },
          { "selector": "license",    "text": "license",    "type": "string" }
        ]
      }]
    }
  ]
}
